# Copy to .env and fill in values. .env is gitignored.
# See _workspace/google-ads-api-checklist.md for context.

# OAuth Client (application identifier — shared across team)
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=

# Developer Token (from MCC account)
GOOGLE_ADS_DEVELOPER_TOKEN=

# Refresh Token (user consent, long-lived)
GOOGLE_ADS_REFRESH_TOKEN=

# MCC ID used as login-customer-id header (digits only, no hyphens)
GOOGLE_ADS_LOGIN_CUSTOMER_ID=

# Test manager 하위 customer account ID (digits only, no hyphens)
GOOGLE_ADS_CUSTOMER_ID=
